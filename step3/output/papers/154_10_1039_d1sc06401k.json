  "paper_analysis": {
    "summary": "This paper reinterprets Mott–Schottky analysis of BiVO4 and hematite photoanodes for water splitting, arguing that many reported very high doping densities are not true bulk dopant densities but artifacts caused by electron injection from the collecting contact during capacitance measurements. Using electrostatic arguments and drift-diffusion/SCAPS simulations, the authors derive a resolution limit for capacitance-based doping detection and conclude that most literature values for these photoanodes lie at or below that limit.",
    "measurement_types": [
      "Mott–Schottky capacitance-voltage measurement",
      "cyclic voltammetry",
      "drift-diffusion simulation",
      "SCAPS device simulation",
      "capacitance profiling / differential capacitance analysis"
    ],
