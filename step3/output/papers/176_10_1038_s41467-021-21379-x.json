  "paper_analysis": {
    "summary": "This paper uses a chromosome-level de novo genome assembly of Hippocampus erectus plus 358 resequenced genomes from 21 seahorse species to reconstruct global seahorse dispersal, demographic history, and phylogeny. The authors conclude that seahorses originated in the Indo-Australian Archipelago ~20–25 Ma, dispersed globally via ocean currents and seaway openings/closures, and repeatedly evolved protective bony spines through convergent changes in bmp3 and other positively selected genes.",
    "measurement_types": [
      "PacBio long-read genome sequencing",
      "Illumina short-read resequencing",
      "Hi-C chromosome conformation capture sequencing",
      "SNP genotyping / variant calling",
      "Phylogenetic inference from genome-wide loci",
      "Population genetics / nucleotide diversity estimation",
      "Demographic inference (G-PhoCS, PSMC)",
      "Positive selection analysis (dN/dS, McDonald-Kreitman tests)",
      "Whole-mount in situ hybridization",
      "CRISPR/Cas9 knockout in zebrafish (functional validation)"
    ],
