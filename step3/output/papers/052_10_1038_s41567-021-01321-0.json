  "paper_analysis": {
    "summary": "This paper studies single-layer 1T-TaSe2, a 2D Mott insulator on a triangular lattice, using STM/STS, ARPES, and XMCD. The authors report Kondo resonances in 1T/1H vertical heterostructures as evidence for localized spins, and energy-dependent long-wavelength spectroscopic modulations in isolated 1T-TaSe2 that they interpret as spinon-density modulations from a quantum spin liquid with a spinon Fermi surface.",
    "measurement_types": [
      "STM topography",
      "STS differential conductance spectroscopy (dI/dV)",
      "constant-height spectroscopic mapping",
      "Fourier transform analysis of STM/STS maps",
      "ARPES",
      "XMCD",
      "DFT+U calculations",
      "tight-binding spinon band simulation",
      "thermal broadening simulation",
      "Fano-line-shape fitting"
    ],
