  "paper_analysis": {
    "summary": "This paper studies how intrinsic TGF-β receptor II (TβRII) signaling in proximal tubule (PT) epithelial cells affects chronic kidney disease progression in an aristolochic acid mouse model. Using spatial transcriptomics, bulk RNA-seq, microscopy, flow cytometry, and biochemical assays, the authors show that PT-specific TβRII deletion worsens mitochondrial injury, impairs complex I and mitochondrial quality control, shifts metabolism toward glycolysis, and amplifies Th1-type renal inflammation and fibrosis. Human kidney snRNA-seq reanalysis supports decreased TGF-β receptor expression and impaired mitochondrial pathways in CKD PT cells.",
    "measurement_types": [
      "spatial transcriptomics (Visium)",
      "bulk RNA-seq",
      "single-nucleus RNA-seq database reanalysis",
      "histology (H&E, Sirius red, Oil Red O)",
      "immunohistochemistry / immunofluorescence",
      "transmission electron microscopy",
      "multiphoton live microscopy / TMRM imaging",
      "flow cytometry (FACS)",
      "RT-qPCR",
      "immunoblotting",
      "bioluminescence assays (ATP, lactate, NAD+/NADH)",
      "Seahorse OCR/ECAR metabolic flux assays"
    ],
