      "X-ray photoemission spectroscopy (XPS)",
      "Ultraviolet photoemission spectroscopy (UPS)",
      "Kelvin probe work-function measurement",
      "Energy-resolved electrochemical impedance spectroscopy (ER-EIS)"
    ],
