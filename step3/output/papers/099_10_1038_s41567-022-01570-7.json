      "four-terminal electrical transport",
      "temperature-dependent resistivity",
      "zero-field transverse voltage / transverse resistivity",
      "mean free path estimation from transport",
      "focused ion beam (FIB) microfabrication",
      "Boltzmann transport simulation",
      "Monte Carlo ballistic transport simulation"
    ],
