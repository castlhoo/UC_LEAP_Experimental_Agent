  "paper_analysis": {
    "summary": "This paper studies Al–AlOx–Al tunnel Josephson junctions used in transmon qubits and shows that the standard sinusoidal current-phase relation is insufficient to explain measured spectra. By fitting spectroscopy data from multiple laboratories with Hamiltonians including higher Josephson harmonics, the authors find percent-level second-harmonic contributions and show these harmonics can strongly affect charge dispersion and qubit design tradeoffs.",
    "measurement_types": [
      "microwave spectroscopy of transmon transition frequencies",
      "resonator spectroscopy / dispersive readout frequency shifts",
      "charge-dispersion measurements versus offset charge",
      "magnetic-field-dependent spectroscopy",
      "STEM imaging of tunnel barriers",
      "scanning electron microscopy of junctions",
      "molecular dynamics simulations of barrier structure"
    ],
